DEBUG=true

TELEGRAM_KEY_BOT="<TOKEN_BOT>"
ID_ADMIN=<ID_ADMIN>

# Admin IDs (comma-separated Telegram user IDs with access to admin commands)
ADMIN_IDS=123456789,987654321

# Redis
REDIS_URL=redis://localhost:6379/0

# Cache API
VIA_CACHE_TTL=60
MAX_CONCURRENT_SENDS=20

# DB Sync - intervalo en segundos para sincronizar API → DB (default: 900 = 15 min)
DB_SYNC_INTERVAL_SECONDS=900

# web Scrapping
URL_SCRAPPING_WEB="<CONSULTA_VIAS_URL>"

DB_NAME='ecuavias.db'
CACHE_NAME='ecuavias.db'
#Tiempo de duracion de cache
CACHE_TIME_EXPIRATION=1800

#Tiempo de cada ciclo de validacion para sincroniar
SYNCDB_REFRESH_TIME=5
#tiempo para revisar la data
SYNCDB_TIME=900
DAYS_TO_KEEP_DATA=<DAYS_TO_DELETE_DATA>